{
  "name": "fluid-client",
  "version": "0.1.0",
  "description": "Fluid client library for gasless Stellar transactions",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "analyze": "tsup src/index.ts --format esm --metafile && echo 'Analyze metafile with a tool or visualizer'"
  },
  "keywords": [
    "stellar",
    "fee-bump",
    "gasless"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@stellar/stellar-sdk": "^11.3.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3"
  }
}
